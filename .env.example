# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_RAW=raw-events
KAFKA_TOPIC_FEATURES=features
KAFKA_TOPIC_ALERTS=anomaly-alerts

# Redis
REDIS_URL=redis://localhost:6379/0
ALERT_DEDUP_TTL=300

# Postgres
POSTGRES_URL=postgresql://sentinel:sentinel123@localhost:5432/streamsentinel

# API
API_HOST=0.0.0.0
API_PORT=8000

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Model
MODEL_PATH=model/artifacts/model.pt
SCALER_PATH=model/artifacts/scaler.pkl
THRESHOLD_PATH=model/artifacts/threshold.json